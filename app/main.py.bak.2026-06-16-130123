@app.get("/game", response_class=HTMLResponse)
def game(request: Request):
    user = get_current_user(request)
    if not user:
        return RedirectResponse("/login", status_code=303)

    result_flag = request.query_params.get("result", "")
    selected_raw = request.query_params.get("selected", "")
    try:
        selected_answer = int(selected_raw) if selected_raw else None
    except Exception:
        selected_answer = None

    state = start_game_if_ready(reset_stale_waiting_state_if_needed(load_game_state()))
    save_game_state(state)

    if state["status"] == "waiting":
        return RedirectResponse("/waiting", status_code=303)
    if state["status"] == "finished":
        return RedirectResponse("/result", status_code=303)

    participants = state.get("participants", [])
    if not participants:
        return RedirectResponse("/waiting", status_code=303)

    now = int(time.time())
    started_at = int(state.get("turn_started_at", now))
    if now - started_at >= TIMER_SECONDS:
        turn_user = participants[state.get("turn_index", 0) % len(participants)]
        state["scores"][turn_user] = int(state["scores"].get(turn_user, 0)) - TIMEOUT_PENALTY
        state = advance_turn(state)
        state = maybe_finish_game(state)
        save_game_state(state)
        if state["status"] == "finished":
            return RedirectResponse("/result", status_code=303)
        return RedirectResponse("/game", status_code=303)

    turn_index = state.get("turn_index", 0) % len(participants)
    turn_username = participants[turn_index]
    turn_info = get_display_info(turn_username)
    q = get_or_create_question(state)

    if q is None:
        state = maybe_finish_game(state)
        save_game_state(state)
        return RedirectResponse("/result", status_code=303)

    payload = {
        "timer": max(0, TIMER_SECONDS - (int(time.time()) - int(state.get("turn_started_at", int(time.time()))))),
        "turn_name": turn_info["name"],
        "turn_avatar": turn_info["avatar"],
        "is_turn": normalize_username(user["username"]) == normalize_username(turn_username),
        "question": {
            "text": q["question"],
            "options": q["options"],
            "correct_index": int(q["correct_index"]) + 1
        },
        "board": build_board(state),
        "answer_result": result_flag,
        "selected_answer": selected_answer,
        "settings": load_settings(),
    }
    ctx = {"request": request, "payload": payload}
    ctx.update(nav_context(request, "game"))
    return templates.TemplateResponse("game.html", ctx)

@app.post("/answer")
def answer(request: Request, ans: int = Form(...)):
    user = get_current_user(request)
    if not user:
        return RedirectResponse("/login", status_code=303)

    state = load_game_state()
    if state["status"] != "active":
        return RedirectResponse("/home", status_code=303)

    participants = state.get("participants", [])
    if not participants:
        return RedirectResponse("/waiting", status_code=303)

    turn_index = state.get("turn_index", 0) % len(participants)
    turn_username = participants[turn_index]

    if normalize_username(user["username"]) != normalize_username(turn_username):
        return RedirectResponse("/game", status_code=303)

    q = get_or_create_question(state)
    if q is None:
        state["status"] = "finished"
        save_game_state(state)
        return RedirectResponse("/result", status_code=303)

    correct = int(q["correct_index"]) + 1
    result_flag = "wrong"

    if int(ans) == correct:
        state["scores"][turn_username] = int(state["scores"].get(turn_username, 0)) + CORRECT_SCORE
        result_flag = "correct"
    else:
        state["scores"][turn_username] = int(state["scores"].get(turn_username, 0)) - WRONG_PENALTY

    state = maybe_finish_game(state)
    save_game_state(state)

    if state["status"] == "finished":
        return RedirectResponse("/result", status_code=303)

    return RedirectResponse(f"/game?result={result_flag}&selected={int(ans)}", status_code=303)


def get_leaderboard():
    users = load_users()
    users.sort(key=lambda x: int(x.get("wallet", 0)), reverse=True)
    return users[:5]

def build_board(state):
    board = []
    for username in state.get("participants", []):
        info = get_display_info(username)
        board.append({
            "username": username,
            "name": info["name"],
            "avatar": info["avatar"],
            "score": int(state.get("scores", {}).get(username, 0)),
        })
    board.sort(key=lambda x: x["score"], reverse=True)
    return board

def maybe_finish_game(state):
    scores = state.get("scores", {})
    if any(v >= WIN_SCORE for v in scores.values()):
        state["status"] = "finished"
        state["finished_at"] = int(time.time())
    if state.get("status") == "finished" and not state.get("winner_awarded"):
        board = build_board(state)
        users = load_users()
        for i, item in enumerate(board[:3]):
            reward = RANK_COINS[i] if i < len(RANK_COINS) else 0
            for u in users:
                if normalize_username(u.get("username")) == normalize_username(item["username"]):
                    u["wallet"] = int(u.get("wallet", 0)) + reward
                    break
        save_users(users)
        state["winner_awarded"] = True
    return state

def get_or_create_question(state):
    if state.get("current_question"):
        return state["current_question"]

    questions = load_questions()
    used = [int(x) for x in state.get("used", []) if isinstance(x, int) or str(x).isdigit()]
    available_indexes = [i for i in range(len(questions)) if i not in used]

    if len(available_indexes) < 5:
        questions = ensure_question_pool(questions, min_count=len(questions) + 20)
        available_indexes = [i for i in range(len(questions)) if i not in used]

    if not available_indexes:
        state["status"] = "finished"
        state["finished_at"] = int(time.time())
        state["current_question"] = None
        save_game_state(state)
        return None

    q_index = random.choice(available_indexes)
    q = questions[q_index]
    state["used"].append(q_index)
    state["current_question"] = q
    state["turn_started_at"] = int(time.time())
    save_game_state(state)
    return q

def advance_turn(state):
    participants = state.get("participants", [])
    if not participants:
        return state
    state["turn_index"] = (int(state.get("turn_index", 0)) + 1) % len(participants)
    state["current_question"] = None
    state["turn_started_at"] = int(time.time())
    return state

def start_game_if_ready(state):
    participants = []
    seen = set()
    for p in state.get("participants", []):
        n = normalize_username(p)
        if n and n not in seen:
            participants.append(n)
            seen.add(n)
    state["participants"] = participants

    for p in participants:
        state["scores"].setdefault(p, 0)

    if len(participants) >= REQUIRED_PLAYERS and state.get("status") == "waiting":
        state["status"] = "active"
        state["turn_index"] = 0
        state["current_question"] = None
        state["turn_started_at"] = int(time.time())
        state["used"] = []
        state["winner_awarded"] = False
        state["finished_at"] = 0
    return state


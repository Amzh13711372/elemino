@app.post("/forgot-password")
def forgot_password(username: str = Form(...), nid: str = Form(...), new_password: str = Form(...)):
    username = normalize_username(username)
    nid = str(nid).strip()

    if not valid_nid(nid):
        return RedirectResponse("/forgot-password?error=nid", status_code=303)
    if len(new_password) < 4:
        return RedirectResponse("/forgot-password?error=shortpass", status_code=303)

    users = load_users()
    found = None
    for u in users:
        if normalize_username(u.get("username")) == username and str(u.get("nid", "")).strip() == nid:
            found = u
            break

    if not found:
        return RedirectResponse("/forgot-password?error=notfound", status_code=303)


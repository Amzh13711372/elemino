        state["participants"].append(username)

    state["scores"].setdefault(username, 0)
    state = start_game_if_ready(state)
    save_game_state(state)

    if state["status"] == "active":
        return RedirectResponse("/game", status_code=303)
    if state["status"] == "finished":
        return RedirectResponse("/result", status_code=303)

    players = []
    for p in state["participants"]:
        info = get_display_info(p)
        players.append({"name": info["name"], "avatar": info["avatar"]})

    ctx = {
        "request": request,
        "count": len(state["participants"]),
        "required_players": REQUIRED_PLAYERS,
        "players": players,
        "auto_refresh": True,
        "settings": load_settings(),
    }
    ctx.update(nav_context(request, "waiting"))
    return templates.TemplateResponse("waiting.html", ctx)


def load_json(path, default):
    if not os.path.exists(path):
        return default
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default

def save_json(path, data):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def normalize_username(username: str):
    return (username or "").strip().lower()

def hash_password(password: str):
    return hashlib.sha256(password.encode("utf-8")).hexdigest()

def is_sha256(value: str):
    if not isinstance(value, str) or len(value) != 64:
        return False
    try:
        int(value, 16)
        return True
    except Exception:
        return False

def load_users():
    users = load_json(USERS_FILE, [])
    if not isinstance(users, list):
        return []
    fixed = []
    changed = False
    for u in users:
        if not isinstance(u, dict):
            continue
        username = normalize_username(u.get("username", ""))
        if not username:
            continue
        item = {
            "name": str(u.get("name", username)).strip() or username,
            "username": username,
            "password": str(u.get("password", "")),
            "nid": str(u.get("nid", "")).strip(),
            "avatar": u.get("avatar") or DEFAULT_AVATAR,
            "wallet": int(u.get("wallet", 0) or 0),
        }
        if item != u:
            changed = True
        fixed.append(item)
    if changed:
        save_json(USERS_FILE, fixed)
    return fixed

def save_users(users):
    save_json(USERS_FILE, users)

def find_user(username):
    uname = normalize_username(username)
    users = load_users()
    return next((u for u in users if normalize_username(u.get("username")) == uname), None)

def verify_password(user, password):
    saved = str(user.get("password", ""))
    if is_sha256(saved):
        return saved == hash_password(password)
    return saved == password

def migrate_user_password_if_needed(user, password):
    saved = str(user.get("password", ""))
    if not is_sha256(saved) and saved == password:
        users = load_users()
        uname = normalize_username(user.get("username"))
        for u in users:
            if normalize_username(u.get("username")) == uname:
                u["password"] = hash_password(password)
                break
        save_users(users)


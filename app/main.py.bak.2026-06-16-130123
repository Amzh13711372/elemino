def valid_nid(nid):
    nid = str(nid).strip()
    if not nid.isdigit() or len(nid) != 10:
        return False
    if len(set(nid)) == 1:
        return False
    check = int(nid[-1])
    s = sum(int(nid[i]) * (10 - i) for i in range(9)) % 11
    return (check == s) if s < 2 else (check == 11 - s)

def save_uploaded_avatar(upload: UploadFile):
    if not upload or not upload.filename:
        return None
    ext = os.path.splitext(upload.filename)[1].lower()
    if ext not in [".jpg", ".jpeg", ".png", ".webp"]:
        return None
    filename = f"{uuid.uuid4().hex}{ext}"
    file_path = os.path.join(UPLOAD_DIR, filename)
    with open(file_path, "wb") as buffer:
        shutil.copyfileobj(upload.file, buffer)
    return f"/static/uploads/{filename}"

def normalize_question_item(q):
    if not isinstance(q, dict):
        return None
    text = str(q.get("question", "")).strip()
    options = q.get("options", [])
    correct_index = q.get("correct_index", 0)
    category = str(q.get("category", "عمومی")).strip() or "عمومی"
    if not text or not isinstance(options, list) or len(options) != 4:
        return None
    try:
        correct_index = int(correct_index)
    except Exception:
        correct_index = 0
    if correct_index < 0 or correct_index > 3:
        correct_index = 0
    return {
        "question": text,
        "options": [str(x).strip() for x in options],
        "correct_index": correct_index,
        "category": category
    }

def load_questions():
    data = load_json(QUESTIONS_FILE, FALLBACK_QUESTIONS)
    if not isinstance(data, list):
        data = FALLBACK_QUESTIONS
    cleaned = []
    seen_texts = set()
    for q in data:
        item = normalize_question_item(q)
        if not item:
            continue
        if item["question"] in seen_texts:
            continue
        seen_texts.add(item["question"])
        cleaned.append(item)
    if not cleaned:
        cleaned = FALLBACK_QUESTIONS[:]
        save_questions(cleaned)
    if len(cleaned) < 30:
        cleaned = ensure_question_pool(cleaned, min_count=40)
    return cleaned

def save_questions(questions):
    normalized = []
    seen = set()
    for q in questions:
        item = normalize_question_item(q)
        if not item:
            continue
        if item["question"] in seen:
            continue
        seen.add(item["question"])
        normalized.append(item)
    save_json(QUESTIONS_FILE, normalized)

def make_mcq(question, correct_answer, wrong_answers, category="عمومی"):
    options = [correct_answer] + wrong_answers[:3]
    random.shuffle(options)
    correct_index = options.index(correct_answer)
    return {
        "question": question,
        "options": options,
        "correct_index": correct_index,
        "category": category
    }

def generate_math_question():
    mode = random.choice(["add", "sub", "mul"])
    if mode == "add":
        a, b = random.randint(5, 80), random.randint(5, 80)
        correct = str(a + b)
        wrongs = list({str(a + b + random.randint(1, 9)), str(a + b - random.randint(1, 7)), str(a + b + random.randint(10, 20))})
        while len(wrongs) < 3:
            wrongs.append(str(a + b + random.randint(2, 15)))
        return make_mcq(f"حاصل {a} + {b} چند می‌شود؟", correct, wrongs[:3], "ریاضی")
    if mode == "sub":
        a, b = random.randint(30, 100), random.randint(1, 29)
        correct = str(a - b)
        wrongs = list({str(a - b + random.randint(1, 7)), str(a - b - random.randint(1, 7)), str(a - b + random.randint(8, 14))})
        while len(wrongs) < 3:
            wrongs.append(str(a - b + random.randint(2, 15)))
        return make_mcq(f"حاصل {a} - {b} چند می‌شود؟", correct, wrongs[:3], "ریاضی")
    a, b = random.randint(2, 12), random.randint(2, 12)
    correct = str(a * b)
    wrongs = list({str(a * b + random.randint(1, 8)), str(a * b - random.randint(1, 6)), str((a+1) * b)})
    while len(wrongs) < 3:
        wrongs.append(str(a * b + random.randint(2, 15)))
    return make_mcq(f"حاصل {a} × {b} چند می‌شود؟", correct, wrongs[:3], "ریاضی")

def generate_capital_question():
    country, capital = random.choice(list(COUNTRIES.items()))
    wrongs = random.sample([v for k, v in COUNTRIES.items() if v != capital], 3)
    return make_mcq(f"پایتخت {country} کدام است؟", capital, wrongs, "جغرافیا")

def generate_chem_question():
    name, formula = random.choice(list(CHEMISTRY.items()))
    wrongs = random.sample([v for k, v in CHEMISTRY.items() if v != formula], min(3, len(CHEMISTRY)-1))
    while len(wrongs) < 3:
        wrongs.append(random.choice(["H2", "N2", "CaCO3", "CH4"]))
        wrongs = list(dict.fromkeys(wrongs))
    return make_mcq(f"فرمول شیمیایی {name} چیست؟", formula, wrongs[:3], "علوم")

def generate_planet_question():
    clue, answer = random.choice(list(PLANETS.items()))
    pool = ["مریخ", "مشتری", "زحل", "عطارد", "زمین", "زهره", "اورانوس", "نپتون"]
    wrongs = random.sample([x for x in pool if x != answer], 3)
    return make_mcq(f"کدام گزینه {clue} است؟", answer, wrongs, "نجوم")

def generate_month_question():
    idx = random.randint(0, len(MONTHS)-1)
    answer = MONTHS[idx]
    qtype = random.choice(["num_to_month", "month_to_num"])
    if qtype == "num_to_month":
        wrongs = random.sample([m for m in MONTHS if m != answer], 3)
        return make_mcq(f"ماه شماره {idx+1} سال شمسی کدام است؟", answer, wrongs, "عمومی")
    correct = str(idx+1)
    wrongs = random.sample([str(i) for i in range(1, 13) if i != idx+1], 3)
    return make_mcq(f"{answer} چندمین ماه سال شمسی است؟", correct, wrongs, "عمومی")

def generate_smart_question():
    generator = random.choice([
        generate_math_question,
        generate_capital_question,
        generate_chem_question,
        generate_planet_question,
        generate_month_question
    ])
    return generator()

def ensure_question_pool(existing_questions, min_count=40):
    questions = existing_questions[:]
    seen = {q["question"] for q in questions if isinstance(q, dict) and q.get("question")}
    tries = 0
    while len(questions) < min_count and tries < 300:
        tries += 1
        q = normalize_question_item(generate_smart_question())
        if not q:
            continue
        if q["question"] in seen:
            continue
        seen.add(q["question"])
        questions.append(q)
    save_questions(questions)
    return questions


@app.post("/register")
def register(
    request: Request,
    name: str = Form(...),
    username: str = Form(...),
    password: str = Form(...),
    nid: str = Form(...),
    accept_rules: str = Form(None),
    avatar_file: UploadFile = File(None),
):
    username = normalize_username(username)
    name = str(name).strip()
    nid = str(nid).strip()

    if accept_rules != "yes":
        return RedirectResponse("/register?error=rules", status_code=303)
    if len(password) < 4:
        return RedirectResponse("/register?error=shortpass", status_code=303)
    if not valid_nid(nid):
        return RedirectResponse("/register?error=nid", status_code=303)

    users = load_users()
    if any(normalize_username(u.get("username")) == username for u in users):
        return RedirectResponse("/register?error=exist", status_code=303)

    avatar = save_uploaded_avatar(avatar_file) or random.choice(AVATARS)
    users.append({
        "name": name or username,
        "username": username,
        "password": hash_password(password),
        "nid": nid,
        "avatar": avatar,
        "wallet": 0,
    })
    save_users(users)
    return RedirectResponse("/login?registered=1", status_code=303)


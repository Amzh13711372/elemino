@app.post("/profile")
def profile(
    request: Request,
    name: str = Form(...),
    username: str = Form(...),
    current_password: str = Form(""),
    new_password: str = Form(""),
    avatar_file: UploadFile = File(None),
):
    current_user = get_current_user(request)
    if not current_user:
        return RedirectResponse("/login", status_code=303)

    new_username = normalize_username(username)
    users = load_users()

    if new_username != normalize_username(current_user["username"]):
        if any(normalize_username(u.get("username")) == new_username for u in users):
            return RedirectResponse("/profile?error=exist", status_code=303)

    old_username = normalize_username(current_user["username"])

    for u in users:
        if normalize_username(u.get("username")) == old_username:
            u["name"] = str(name).strip() or u["name"]
            u["username"] = new_username

            if new_password:
                if len(new_password) < 4:
                    return RedirectResponse("/profile?error=shortpass", status_code=303)
                if not current_password:
                    return RedirectResponse("/profile?error=current_required", status_code=303)
                if not verify_password(u, current_password):
                    return RedirectResponse("/profile?error=pass", status_code=303)
                u["password"] = hash_password(new_password)

            avatar = save_uploaded_avatar(avatar_file)
            if avatar:
                u["avatar"] = avatar
            break

    save_users(users)

    state = load_game_state()
    state["participants"] = [new_username if normalize_username(p) == old_username else p for p in state.get("participants", [])]
    if old_username in state.get("scores", {}):
        state["scores"][new_username] = state["scores"].pop(old_username)
    save_game_state(state)

    resp = RedirectResponse("/profile?updated=1", status_code=303)
    resp.set_cookie("username", new_username, httponly=True, samesite="lax")
    return resp

